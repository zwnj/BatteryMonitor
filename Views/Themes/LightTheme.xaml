<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Window/Background (Windows 11 Mica-like light gray) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#E5E5E5"/>
    
    <!-- Cards/Panels (White with subtle elevation/separation) -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#4DFFFFFF"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#5C5C5C"/>
    
    <!-- Status Colors -->
    <SolidColorBrush x:Key="OrdinaryStatusBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ChargingStatusBrush" Color="#008000"/> <!-- Darker Green for visibility on light bg -->
    
    <!-- Icons/UI -->
    <SolidColorBrush x:Key="SettingsIconBrush" Color="#424242"/>

    <!-- Toggle Switch -->
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#66505050"/>
    
    <!-- Pin Active -->
    <Color x:Key="PinActiveColor">#00FF00</Color>
    <SolidColorBrush x:Key="PinActiveBrush" Color="{StaticResource PinActiveColor}"/>
    <SolidColorBrush x:Key="PinGlowBrush" Color="#00FF00"/>

    <SolidColorBrush x:Key="IconDefaultBrush" Color="#555555"/>

    <sys:Double x:Key="PinGlowOpacity">0</sys:Double>
    <sys:Double x:Key="PinGlowRadius">0.0</sys:Double>
</ResourceDictionary>
