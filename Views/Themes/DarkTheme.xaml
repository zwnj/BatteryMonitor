<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Window/Background -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#331E1E1E"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush_Opaque" Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#333333"/>
    
    <!-- Cards/Panels -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#662D2D30"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#888888"/>
    
    <!-- Status Colors -->
    <SolidColorBrush x:Key="OrdinaryStatusBrush" Color="White"/>
    <SolidColorBrush x:Key="ChargingStatusBrush" Color="#90EE90"/> <!-- LightGreen -->
    
    <!-- Icons/UI -->
    <SolidColorBrush x:Key="IconDefaultBrush" Color="Gray"/>
    <SolidColorBrush x:Key="SettingsIconBrush" Color="White"/>
    
    <!-- Toggle Switch -->
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#6634323D"/>
    
    <!-- Pin Active -->
    <Color x:Key="PinActiveColor">#00FF00</Color>
    <SolidColorBrush x:Key="PinActiveBrush" Color="{StaticResource PinActiveColor}"/>
    <sys:Double x:Key="PinGlowOpacity">0.6</sys:Double>
    <sys:Double x:Key="PinGlowRadius">8</sys:Double>
</ResourceDictionary>
