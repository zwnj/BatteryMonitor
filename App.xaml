<Application x:Class="BatteryMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:BatteryMonitor.Views"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <tb:TaskbarIcon x:Key="MyNotifyIcon"
                        IconSource="{Binding TrayIconSource}"
                        PopupActivation="None"
                        ToolTipText="Battery Monitor beta">
            
                <tb:TaskbarIcon.TrayPopup>
                    <views:PopupView />
                </tb:TaskbarIcon.TrayPopup>

                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="更新を確認" Click="CheckUpdates_Click" />
                        <MenuItem Header="終了" Click="Exit_Click" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
