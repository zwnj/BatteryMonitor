<UserControl x:Class="BatteryMonitor3.PopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="320">
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#333333" BorderThickness="1"
            Height="450" Width="320">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Battery Monitor" Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center"/>
                <Button Content="⚙" HorizontalAlignment="Right" 
                        Background="Transparent" BorderBrush="Transparent" Foreground="White" FontSize="16"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,30">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⚡" Foreground="{Binding StatusColor}" FontSize="32" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding BatteryLevel}" Foreground="White" FontSize="48" FontWeight="Bold"/>
                    <TextBlock Text="%" Foreground="#AAAAAA" FontSize="24" VerticalAlignment="Bottom" Margin="5,0,0,8"/>
                </StackPanel>

                <TextBlock Text="{Binding MainStatusText}" 
                           Foreground="{Binding StatusColor}"
                           FontSize="16" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,5,0,0"/>

                <TextBlock Text="{Binding SubStatusText}" 
                           Foreground="#888888" 
                           FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="2" Rows="2">
                <UniformGrid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Padding" Value="10"/>
                    </Style>
                    <Style TargetType="TextBlock" x:Key="LabelStyle">
                        <Setter Property="Foreground" Value="#888888"/>
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                    <Style TargetType="TextBlock" x:Key="ValueStyle">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                    </Style>
                </UniformGrid.Resources>

                <Border>
                    <StackPanel>
                        <TextBlock Text="POWER RATE" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding PowerRate}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border>
                    <StackPanel>
                        <TextBlock Text="VOLTAGE" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Voltage}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border>
                    <StackPanel>
                        <TextBlock Text="CYCLE COUNT" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding CycleCount}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border>
                    <StackPanel>
                        <TextBlock Text="HEALTH" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Health}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
